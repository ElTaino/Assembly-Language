_start:

;# rdx cleared because if it is
;# a big number or fraction then
;# it will flow into rdx with rax

;# This means rdx can be MOD

;# Also need to clear out b/c
;# it is counted with the function

xor rdx, rdx
mov rax, 6
mov rbx, 4
div rbx

int3
xor rdx, rdx
mov rax, -7

;# Quad to Octo word
;# Pretty much do whatever you 
;# need to do make sure it works
;# with rdx
cqo 
mov rsi, 4
idiv rsi

mov rax, 5
mov rdx, 3
mul rdx;# puts the result in rbx


;# Manual mult
mov rbx, 3
mul rbx, 2 ;#result 6

;# handles negative numbers
mov rax, -2
mov rdx, 3 
imul rdx

int3
mov rax, 3
mov rbx, 4
mov rdx, 2
imul rdx, rbx

xor rdx, rdx
mov rax, 15
mov rcx, 7

