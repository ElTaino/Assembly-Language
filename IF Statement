.intel_syntax noprefix
.global _start
.text
_start:

mov rax, 3

;# IF <condition>
;# compare (Does all operations)
cmp rax, 4
;# jump if not equal
;# probably other commands
jne exit

;# body
print:
 mov rax, 1
 mov rdi, 1
 lea rsi, [s1]
 lea rdx, [s1_len]
 syscall

;# end if 
exit:
 mov rax, 60
 xor rdi, rdi
 syscall

.data
 s1: .ascii "rax is like 3!"
 s1_len = . - s1

